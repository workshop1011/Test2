# 2-2. 강력한 통합 검색 도구 정의
def search_integrated_risk(company_name: str, keyword: str) -> str:
    """
    주어진 기업과 리스크 키워드에 대해 네이버(뉴스)와 구글(DART 공시)을 동시 검색합니다.
    """
    search_query = f"{company_name} {keyword}"
    combined_results = []

    # 1. 네이버 뉴스 검색 (한국어 자연어 이슈 탐지)
    try:
        naver_url = "https://openapi.naver.com/v1/search/news.json"
        naver_headers = {
            "X-Naver-Client-Id": NAVER_CLIENT_ID,
            "X-Naver-Client-Secret": NAVER_CLIENT_SECRET
        }
        naver_params = {"query": search_query, "display": 3, "sort": "date"} # 최신순 3개
        naver_res = requests.get(naver_url, headers=naver_headers, params=naver_params)

        if naver_res.status_code == 200:
            n_items = naver_res.json().get('items', [])
            if n_items:
                combined_results.append("=== [Naver News] ===")
                for item in n_items:
                    # HTML 태그 제거 및 정리
                    title = item['title'].replace('<b>', '').replace('</b>', '').replace('&quot;', '')
                    combined_results.append(f"- 제목: {title}")
    except Exception as e:
        combined_results.append(f"네이버 검색 오류: {str(e)}")

    # 2. 구글 DART 공시 검색 (site:dart.fss.or.kr 제한 쿼리)
    try:
        google_url = "https://www.googleapis.com/customsearch/v1"
        google_params = {
            "key": GOOGLE_API_KEY,
            "cx": GOOGLE_CX,
            "q": f"{search_query} site:dart.fss.or.kr",
            "num": 3
        }
        google_res = requests.get(google_url, params=google_params)

        if google_res.status_code == 200:
            g_items = google_res.json().get('items', [])
            if g_items:
                combined_results.append("\n=== [Google DART Search] ===")
                for item in g_items:
                    combined_results.append(f"- 공시제목: {item['title']}")
                    combined_results.append(f"  요약: {item['snippet']}")
    except Exception as e:
        combined_results.append(f"구글 검색 오류: {str(e)}")

    # 3. 결과 종합
    if not combined_results:
        return f"'{search_query}'에 대한 최근 뉴스 및 공시 검색 결과가 없습니다. (해당 리스크 없음)"

    return "\n".join(combined_results)

